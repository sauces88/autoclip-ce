# AutoClip 环境变量配置示例
# 复制此文件为 .env 并填入实际配置

# 数据库配置（默认使用 SQLite，无需安装 MySQL）
DATABASE_URL="mysql+pymysql://root:41321321.00@localhost:3306/autoclip?charset=utf8mb4"
# DATABASE_URL="sqlite:///autoclip.db"

# Redis配置
REDIS_URL="redis://localhost:6379/10"

# API配置
API_LLM_PROVIDER="gemini"
GEMINI_API_KEY="AIzaSyASLJPXbK4zCgRYmLYzlucVbMBFC2Cj3gQ"
API_MODEL_NAME="gemini-3.1-flash-lite-preview"
API_MAX_TOKENS=8192
API_TIMEOUT=30

# 字幕LLM纠错（true=启用，false=不启用）
SUBTITLE_LLM_CORRECTION=true

# 处理配置
PROCESSING_CHUNK_SIZE=5000
PROCESSING_MIN_SCORE_THRESHOLD=0.7
PROCESSING_MAX_CLIPS_PER_COLLECTION=5
PROCESSING_MAX_RETRIES=3

# 路径配置（可选，系统会自动检测）
# PATH_PROJECT_ROOT=
# PATH_DATA_DIR=
# PATH_UPLOADS_DIR=
# PATH_TEMP_DIR=
# PATH_OUTPUT_DIR=

# 火山引擎语音识别配置（录音文件识别标准版 Seed ASR AUC）
